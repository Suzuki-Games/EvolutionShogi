# Auto detect text files and perform LF normalization
* text=auto

# Unity serialized files
*.meta text eol=lf
*.unity text eol=lf
*.asset text eol=lf
*.prefab text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.overrideController text eol=lf
*.physicMaterial text eol=lf
*.physicsMaterial2D text eol=lf
*.playable text eol=lf
*.mixer text eol=lf
*.shadergraph text eol=lf
*.shadersubgraph text eol=lf
*.renderTexture text eol=lf
*.brush text eol=lf
*.terrainlayer text eol=lf
*.giparams text eol=lf
*.lighting text eol=lf
*.scenetemplate text eol=lf

# Script files
*.cs text eol=lf
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.compute text eol=lf

# Config files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf
*.txt text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.tga binary
*.tif binary
*.tiff binary
*.psd binary
*.exr binary
*.hdr binary
*.wav binary
*.mp3 binary
*.ogg binary
*.aif binary
*.fbx binary
*.obj binary
*.blend binary
*.dll binary
*.so binary
*.a binary
*.exe binary
*.pdf binary
*.ttf binary
*.otf binary
*.cubemap binary
